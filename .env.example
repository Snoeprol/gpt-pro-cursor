# Your OpenAI API key
OPENAI_API_KEY=sk-...

# Port the proxy listens on (default: 3045)
PORT=3045

# Model to forward all Cursor requests to.
# Must match the model name you add in Cursor Settings → Models.
# Examples: gpt-5.4-pro  |  gpt-5.4  |  gpt-5.4-mini  |  o3  |  gpt-4.1
TARGET_MODEL=gpt-5.4-pro
